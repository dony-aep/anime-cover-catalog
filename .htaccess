# Deny access to AnimeImages directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteCond %{REQUEST_URI} ^/AnimeImages/$ [OR]
    RewriteCond %{REQUEST_URI} ^/AnimeImages$
    RewriteRule ^(.*)$ / [R=301,L]
</IfModule>

# Alternative method if mod_rewrite is not available
<IfModule !mod_rewrite.c>
    <Files "AnimeImages/*">
        Order Allow,Deny
        Deny from all
    </Files>
</IfModule>